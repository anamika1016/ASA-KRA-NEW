<div class="login-network-page">
  <div class="login-network-page__background" aria-hidden="true">
    <span class="network-orbit orbit-1"></span>
    <span class="network-orbit orbit-2"></span>
    <span class="network-orbit orbit-3"></span>
    <span class="network-orbit orbit-4"></span>
    <span class="network-orbit orbit-5"></span>
    <span class="network-orbit orbit-6"></span>

    <div class="network-person person-1">
      <span class="network-person__avatar avatar-sky"></span>
    </div>
    <div class="network-person person-2">
      <span class="network-person__avatar avatar-indigo"></span>
    </div>
    <div class="network-person person-3 person-large">
      <span class="network-person__avatar avatar-cobalt"></span>
    </div>
    <div class="network-person person-4">
      <span class="network-person__avatar avatar-sand"></span>
    </div>
    <div class="network-person person-5">
      <span class="network-person__avatar avatar-teal"></span>
    </div>
    <div class="network-person person-6">
      <span class="network-person__avatar avatar-navy"></span>
    </div>
    <div class="network-person person-7">
      <span class="network-person__avatar avatar-rose"></span>
    </div>
    <div class="network-person person-8">
      <span class="network-person__avatar avatar-mint"></span>
    </div>
  </div>

  <div class="login-network-card">
    <section class="login-network-hero">
      <div class="login-network-hero__slider" aria-hidden="true">
        <div class="hero-slide hero-slide--one">
          <%= image_tag "pexels-mizunokozuki-12899140.jpg", class: "hero-slide__image", alt: "", loading: "eager" %>
        </div>
        <div class="hero-slide hero-slide--two">
          <%= image_tag "pexels-n-voitkevich-5412159.jpg", class: "hero-slide__image", alt: "", loading: "eager" %>
        </div>
      </div>

      <div class="login-network-hero__content">
        <div class="login-network-hero__brand">
          <div>
            <p class="login-network-hero__eyebrow">Performance Network</p>
            <h1>Welcome back</h1>
          </div>
        </div>

        <p class="login-network-hero__copy">
          A cleaner sign-in experience with the connected-team style you shared, while keeping your login behavior unchanged.
        </p>

        <div class="login-network-hero__indicators" aria-hidden="true">
          <span class="hero-indicator hero-indicator--one"></span>
          <span class="hero-indicator hero-indicator--two"></span>
        </div>
      </div>
    </section>

    <section class="login-network-form-panel">
      <div class="login-network-form-panel__header">
        <span class="login-network-form-panel__eyebrow">Employee Login</span>
        <h2>Sign in to continue</h2>
        <p>Use your employee code and password to sign in.</p>
        <details class="login-network-form-panel__disclosure">
          <summary class="login-network-form-panel__summary">
            <span class="login-network-form-panel__summary-label">Need login help?</span>
          </summary>
          <div class="login-network-form-panel__note">
            If your name already exists in Employee List, your account is created automatically. Use default password <strong>123456</strong> and your employee code to log in.
          </div>
        </details>
      </div>

      <% if flash[:alert] %>
        <div class="alert alert-danger"><%= flash[:alert] %></div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false }, class: "login-network-form" }) do |f| %>
        <div class="login-network-form__field">
          <%= f.label :employee_code, "Employee Code", class: "form-label" %>
          <%= f.text_field :employee_code, autofocus: true, required: true, autocomplete: "username", class: "form-control", placeholder: "Enter your employee code" %>
        </div>

        <div class="login-network-form__field">
          <%= f.label :password, class: "form-label" %>
          <div class="password-toggle-wrap" data-controller="password-toggle">
            <%= f.password_field :password, required: true, autocomplete: "current-password", class: "form-control password-toggle-input", placeholder: "Enter password", data: { password_toggle_target: "input" } %>
            <button type="button" class="password-toggle-btn" data-action="click->password-toggle#toggle" data-password-toggle-target="button" aria-label="Show password" aria-pressed="false">
              <svg class="password-toggle-icon" data-password-toggle-target="showIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1.5 12s3.8-6.5 10.5-6.5S22.5 12 22.5 12s-3.8 6.5-10.5 6.5S1.5 12 1.5 12Z"></path>
                <circle cx="12" cy="12" r="3.25"></circle>
              </svg>
              <svg class="password-toggle-icon" data-password-toggle-target="hideIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
                <path d="M3 3l18 18"></path>
                <path d="M10.6 5.7A11.8 11.8 0 0 1 12 5.5c6.7 0 10.5 6.5 10.5 6.5a19.7 19.7 0 0 1-4.1 4.8"></path>
                <path d="M6.2 6.2A19 19 0 0 0 1.5 12s3.8 6.5 10.5 6.5a10.7 10.7 0 0 0 5.2-1.3"></path>
                <path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"></path>
              </svg>
            </button>
          </div>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="login-network-form__options">
            <label class="form-check">
              <%= f.check_box :remember_me, class: "form-check-input" %>
              <span class="form-check-label">Remember me</span>
            </label>
          </div>
        <% end %>

        <div class="login-network-form__actions">
          <%= f.submit "Log in", class: "btn btn-auth" %>
        </div>
      <% end %>

      <div class="login-form-links">
        <%= render "devise/shared/links" %>
      </div>
    </section>
  </div>

  <div class="login-signup-modal" id="signupConfirmModal" hidden>
    <div class="login-signup-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="signupConfirmTitle">
      <h3 id="signupConfirmTitle" class="login-signup-modal__title">Continue to sign up?</h3>
      <p class="login-signup-modal__text">You are about to open the employee registration page.</p>
      <div class="login-signup-modal__actions">
        <button type="button" class="login-signup-modal__btn login-signup-modal__btn--ghost" id="signupConfirmCancelBtn">Cancel</button>
        <button type="button" class="login-signup-modal__btn login-signup-modal__btn--primary" id="signupConfirmBtn">Confirm</button>
      </div>
    </div>
  </div>

  <div class="login-signup-modal" id="signupFinalModal" hidden>
    <div class="login-signup-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="signupFinalTitle">
      <h3 id="signupFinalTitle" class="login-signup-modal__title">Before you continue</h3>
      <p class="login-signup-modal__text">
        Employees already present in Employee List do not need to sign up manually. Their login account is created automatically with default password <strong>123456</strong>.
      </p>
      <div class="login-signup-modal__actions">
        <%= link_to "OK", new_registration_path(resource_name), class: "login-signup-modal__btn login-signup-modal__btn--primary", id: "signupFinalOkBtn" %>
      </div>
    </div>
  </div>
</div>

<style nonce="<%= content_security_policy_nonce %>">
  .login-signup-modal[hidden] { display: none !important; }
  .login-signup-modal:not([hidden]) {
    position: fixed; inset: 0; z-index: 9999; display: flex !important;
    align-items: flex-start; justify-content: center; padding: 2rem 1.5rem 1.5rem;
    background: rgba(16, 33, 54, 0.48);
  }
  .login-signup-modal__dialog {
    width: min(100%, 26rem); padding: 1.5rem; border-radius: 1.25rem;
    border: 1px solid #d7dfeb; background: #fff;
    box-shadow: 0 24px 60px rgba(16, 33, 54, 0.2);
  }
  .login-signup-modal__title {
    margin: 0 0 .75rem; color: #102136; font-size: 1.25rem; font-weight: 700;
  }
  .login-signup-modal__text {
    margin: 0; color: #64748b; font-size: .95rem; line-height: 1.55;
  }
  .login-signup-modal__actions {
    display: flex; justify-content: flex-end; gap: .75rem; margin-top: 1.25rem;
  }
  .login-signup-modal__btn {
    min-width: 6rem; padding: .7rem 1rem; border: 1px solid transparent;
    border-radius: 999px; font-size: .92rem; font-weight: 600;
    text-align: center; text-decoration: none; cursor: pointer;
  }
  .login-signup-modal__btn--ghost {
    border-color: #d7dfeb; background: #fff; color: #64748b;
  }
  .login-signup-modal__btn--primary {
    background: #176b43; color: #fff;
  }
  .signup-dot-btn__dots { display: inline-flex; align-items: center; gap: .2rem; }
  .signup-dot-btn__dots span {
    display: block; width: .38rem; height: .38rem;
    border-radius: 999px; background: #6b7280;
  }
</style>

<script nonce="<%= content_security_policy_nonce %>">
  (function () {
    function initializeSignupPopups() {
      const dot = document.getElementById("signupDotBtn");
      const firstPopup = document.getElementById("signupConfirmModal");
      const secondPopup = document.getElementById("signupFinalModal");
      const cancel = document.getElementById("signupConfirmCancelBtn");
      const confirm = document.getElementById("signupConfirmBtn");
      if (!dot || !firstPopup || !secondPopup || dot.dataset.ready === "true") return;

      dot.dataset.ready = "true";
      const closeAll = function () {
        firstPopup.hidden = true;
        secondPopup.hidden = true;
        document.body.classList.remove("login-modal-open");
      };

      dot.addEventListener("click", function () {
        firstPopup.hidden = false;
        secondPopup.hidden = true;
        document.body.classList.add("login-modal-open");
      });
      cancel.addEventListener("click", closeAll);
      confirm.addEventListener("click", function () {
        firstPopup.hidden = true;
        secondPopup.hidden = false;
      });
      firstPopup.addEventListener("click", function (event) {
        if (event.target === firstPopup) closeAll();
      });
      secondPopup.addEventListener("click", function (event) {
        if (event.target === secondPopup) closeAll();
      });
    }

    document.addEventListener("turbo:load", initializeSignupPopups);
    document.addEventListener("DOMContentLoaded", initializeSignupPopups);
    initializeSignupPopups();
  })();
</script>
